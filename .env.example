# EcoGrid.AI API Credentials Template
# Copy this file to a new file named '.env' and fill in your actual credentials.

# 1. Google Gemini API Key (Required for Page 2 AI Executive Carbon Audit summary)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 2. Google Maps API Key (Required for Page 2 precision geocoding)
# Get a key from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# 3. Mapbox Access Token (Optional: Falls back to premium 'carto-darkmatter' if missing)
# Get a token from Mapbox: https://www.mapbox.com/
MAPBOX_TOKEN=YOUR_MAPBOX_TOKEN_HERE
